# Copy to .env (gitignored). All Rust services read these via dotenvy.
# Values match the port mappings in docker-compose.yml.

RUST_LOG=info

# Redpanda (Kafka API), external listener mapped to the host.
# Topic names are fixed by convention in common::topics (market.trades,
# market.book-tickers, market.klines) — create them with `make topics`.
KAFKA_BROKERS=localhost:19092
KAFKA_GROUP_HOT=hot-consumer-group
KAFKA_GROUP_COLD=cold-consumer-group

# Cold-consumer batching: flush the buffer to Parquet when it reaches this many
# rows OR this many seconds elapse, whichever comes first.
COLD_BATCH_MAX_ROWS=500
COLD_FLUSH_SECS=10

# Binance websocket base endpoint (no path — the ingestor builds the
# combined-stream URL). Verified 2026-07-05 against binance-spot-api-docs:
# data-stream.binance.vision serves market data only, which is all we need.
# Alternative general endpoint: wss://stream.binance.com:9443
BINANCE_WS_BASE=wss://data-stream.binance.vision
# Comma-separated, lowercase stream symbols (see common::symbol::Symbol)
SYMBOLS=btcusdt,ethusdt
# Comma-separated kline intervals; one stream is opened per symbol × interval.
# Valid values are Binance's documented set only — there is no 10m, and a day
# is 1d (not 24h). Defaults to the full set when unset.
#   1s 1m 3m 5m 15m 30m 1h 2h 4h 6h 8h 12h 1d 3d 1w 1M
KLINE_INTERVALS=1s,1m,5m,15m,1h,4h,1d

# Backfill (cargo run -p ingestor --bin backfill / `make backfill`):
# pulls historical klines from Binance's REST API into market.klines so the
# lake has history for intervals the live stream would take days to fill.
BINANCE_REST_BASE=https://data-api.binance.vision
# Candles per symbol × interval; Binance caps this at 1000.
BACKFILL_LIMIT=1000

# MinIO (S3-compatible lake). These are MinIO's well-known DEV DEFAULTS, used
# only for the local stack — NOT secrets. For any real deployment, replace them
# with real credentials supplied via .env (gitignored), never committed.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
LAKE_BUCKET=market-lake

# SpacetimeDB (no trailing slash)
STDB_HTTP_URI=http://localhost:3000
STDB_WS_URI=ws://localhost:3000
STDB_DB_NAME=projectino

# Axum historical-query API
API_LISTEN_ADDR=127.0.0.1:8081
# Browser origin allowed to call the api (the Vite dev server)
API_CORS_ORIGIN=http://localhost:5173
